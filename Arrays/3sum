public int threeSumSmaller(int[] nums, int target) {
        HashMap<Integer,Integer> map=new HashMap<>();
        int n=nums.length;
        int sum=0;
        int count=0;
        for(int i=0;i<n;i++)
        {
            int left=i+1;
            int right=n-1;
            
            
            while(left<right)
            {
                sum=nums[i]+nums[left]+nums[right];
                if(sum<target)
                {
                    count=count+(right-left);
                    left++;
                }
                else{
                    right--;
                }
            }
            
            
        // Your code goes here
    }
    return count;
}
