class Solution {
    public int maxLen(int[] nums) {
        HashMap<Integer,Integer> map=new HashMap<>();
        int n=nums.length;
        int sum=0;
        int maxi=0;
        
        for(int i=0;i<n;i++)
        {
            sum=sum+nums[i];
            if(sum==0)
            {
                maxi=i+1;
            }
            if(map.containsKey(sum))
            {
                maxi=Math.max(maxi,i-map.get(sum));

            }
            else
            {
                map.put(sum,i);
            }
        }
        return maxi;
