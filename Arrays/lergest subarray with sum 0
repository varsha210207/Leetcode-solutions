//brute force

class Solution {
    public int maxLen(int[] nums) {
        int n = nums.length;
        int maxi = 0;

        for(int i = 0; i < n; i++) {
            int sum = 0;
            int count = 0;

            for(int j = i; j < n; j++) {
                sum += nums[j];
                count++;

                if(sum == 0) {
                    maxi = Math.max(maxi, count);
                }
            }
        }
        return maxi;
    }
}


