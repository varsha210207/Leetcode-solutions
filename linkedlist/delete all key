class Solution {
    public ListNode deleteAllOccurrences(ListNode head, int target){
        ListNode temp=head;
        while(temp!=null)
        {
            if(temp.val==target)
            {
                if(temp==head)
                {
                    head=head.next;
                }
                ListNode prevNode=temp.prev;
                ListNode nextNode=temp.next;
                if(prevNode!=null)
                {
                    prevNode.next=nextNode;
                }
                if(nextNode!=null)
                {
                    nextNode.prev=prevNode;
                }
                temp=nextNode;
            }
            
            else{
                temp=temp.next;
            }
        }
            
            return head;
        }
    }
    
    
