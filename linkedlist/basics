    //sum of linked list
    class Node {
    int data;
    Node next;

    Node(int data) {
        this.data = data;
        this.next = null;
    }
}

public class Main {

    static int sumNodes(Node head) { 
        int sum= 0; 
        Node temp = head;

        while (temp != null) {
            sum=sum+temp.data; 
            temp = temp.next;
        }

        return sum; 
    }

    public static void main(String[] args) {

        Node first = new Node(10);
        Node second = new Node(20);
        Node third = new Node(30);
        Node fourth = new Node(40);


        first.next = second;
        second.next = third;
        third.next=fourth;


        Node head = first;

        System.out.println(sumNodes(head)); 
    }
}
